# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/resume-checker

# JWT Configuration
JWT_SECRET=replace_with_secure_secret
JWT_EXPIRE=7d
JWT_COOKIE_EXPIRE=7

# Server Configuration
PORT=5000
NODE_ENV=development

# Client URL
CLIENT_URL=http://localhost:5173

# Email Configuration (Custom SMTP Server)
EMAIL_SERVICE=custom
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=your_email@example.com
EMAIL_PASSWORD=your_email_password
EMAIL_FROM=noreply@example.com

# Groq API Key
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# Resume Analysis Limits (optional)
MAX_RESUME_FILE_SIZE_BYTES=5242880
MAX_RESUME_TEXT_CHARS=18000
MAX_JOB_DESCRIPTION_CHARS=12000
MAX_CHAT_MESSAGE_CHARS=4000